# Pillar A ingestion scheduler
FF_PILLAR_A_INGESTION=false
INGESTION_CRON=0 * * * *
JOB_MAX_RETRIES=3

# Pillar A trend source adapter v1
FF_PILLAR_A_SOURCE_V1=false
PILLAR_A_SOURCE_V1_GEO=US
PILLAR_A_SOURCE_V1_LANG=en-US
PILLAR_A_SOURCE_V1_MAX_PAGES=1
PILLAR_A_SOURCE_V1_TIMEOUT_SECONDS=15
PILLAR_A_SOURCE_V1_VELOCITY_BASELINE=1000
PILLAR_A_SOURCE_V1_CONFIDENCE_BASELINE=0.7

# Pillar A research persistence
RESEARCH_RETENTION_DAYS=30

# Supabase persistent state (Priority 1 — Phase 2)
# Required tables: system_state, events  (see backend/integrations/supabase_client.py)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# FRED / S&P macro signals (Priority 2 — Phase 2)
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key
# Optional S&P Global premium (reserved for future use)
ICE_API_KEY=

# Adobe Journey Optimizer (Priority 3 — Phase 2)
# Bearer token from Adobe Developer Console
ADOBE_AJO_TOKEN=your-ajo-bearer-token
# IMS Organisation ID from Adobe Admin Console
ADOBE_IMS_ORG=your-ims-org-id@AdobeOrg
