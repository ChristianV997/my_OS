# Pillar A ingestion scheduler (set true to enable hourly research runs)
FF_PILLAR_A_INGESTION=true
INGESTION_CRON=0 * * * *
JOB_MAX_RETRIES=3

# Pillar A trend source adapter v1 (set true to enable Google Trends ingestion)
FF_PILLAR_A_SOURCE_V1=true
PILLAR_A_SOURCE_V1_GEO=US
PILLAR_A_SOURCE_V1_LANG=en-US
PILLAR_A_SOURCE_V1_MAX_PAGES=1
PILLAR_A_SOURCE_V1_TIMEOUT_SECONDS=15
PILLAR_A_SOURCE_V1_VELOCITY_BASELINE=1000
PILLAR_A_SOURCE_V1_CONFIDENCE_BASELINE=0.7

# Pillar A research persistence
RESEARCH_RETENTION_DAYS=30
